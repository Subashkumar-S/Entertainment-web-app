# Docker deployment env for the CINEPLAN stack — read by docker-compose.yml and
# docker-compose.dev.yml (run compose from THIS deploy/ directory).
#   cp .env.example .env
#
# Compose-level vars, prefixed CINEPLAN_ so they never clash with other projects
# on a shared host/shell; each is mapped into the container under its normal name
# (MONGODB_URI, SECRET, …), so app code is unchanged. Native development uses the
# repo-root .env with UNPREFIXED names instead — see ../.env.example.

# Required secrets
CINEPLAN_SECRET=replace-with-a-long-random-string
CINEPLAN_TMDB_API_KEY=your-tmdb-v3-api-key

# Host binding & ports
CINEPLAN_BIND_IP=127.0.0.1
CINEPLAN_CLIENT_HOST_PORT=8081
CINEPLAN_SERVER_HOST_PORT=8091
CINEPLAN_PORT=5000
CINEPLAN_MONGO_HOST_PORT=27017
CINEPLAN_REDIS_HOST_PORT=6379

# Public origin / API base
CINEPLAN_CLIENT_ORIGIN=http://localhost:8081
CINEPLAN_VITE_API_BASE_URL=http://localhost:5000/api

# Data stores — bundled mongo/redis containers; change to cloud URLs for managed.
CINEPLAN_MONGODB_URI=mongodb://mongo:27017/cineplan
CINEPLAN_REDIS_URL=redis://redis:6379

# Google OAuth (optional — leave blank to disable the Google button)
CINEPLAN_GOOGLE_CLIENT_ID=
CINEPLAN_GOOGLE_CLIENT_SECRET=
CINEPLAN_GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Reminder email via Resend (optional)
CINEPLAN_RESEND_API_KEY=
CINEPLAN_EMAIL_FROM=Cineplan <onboarding@resend.dev>
