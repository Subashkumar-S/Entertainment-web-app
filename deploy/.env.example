# Docker deployment env for the CINEPLAN stack — read by docker-compose.yml
# and docker-compose.dev.yml when you run compose from THIS deploy/ directory.
#
#   cp .env.example .env     # then fill in the required values below
#
# These are COMPOSE-level variables, prefixed with CINEPLAN_ so they never clash
# with the other projects' settings on a shared host/shell. Compose maps each one
# into the container under its normal, unprefixed name (MONGODB_URI, SECRET, …),
# so the application code is unchanged.
#
# NOTE: native development (cd server && npm run dev / cd client && npm run dev)
# reads the repo-ROOT .env with UNPREFIXED names instead — see ../.env.example.
# This file is only for the all-in-Docker stack.

# ── Required ─────────────────────────────────────────────────────────
CINEPLAN_SECRET=replace-with-a-long-random-string
CINEPLAN_TMDB_API_KEY=your-tmdb-v3-api-key

# ── Host binding & ports (defaults shown) ────────────────────────────
# CINEPLAN_BIND_IP=127.0.0.1
# CINEPLAN_CLIENT_HOST_PORT=8081
# CINEPLAN_SERVER_HOST_PORT=8091
# CINEPLAN_PORT=5000                 # server's in-container port
# CINEPLAN_MONGO_HOST_PORT=27017     # dev stack only
# CINEPLAN_REDIS_HOST_PORT=6379      # dev stack only

# ── Public origin / API base ─────────────────────────────────────────
# On the box behind Caddy: CINEPLAN_CLIENT_ORIGIN=https://cineplan.subashkumar.dev
# CINEPLAN_CLIENT_ORIGIN=http://localhost:8081
# CINEPLAN_VITE_API_BASE_URL=http://localhost:5000/api

# ── Google OAuth (optional) ──────────────────────────────────────────
# CINEPLAN_GOOGLE_CLIENT_ID=
# CINEPLAN_GOOGLE_CLIENT_SECRET=
# CINEPLAN_GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Reminder email via Resend (optional) ─────────────────────────────
# CINEPLAN_RESEND_API_KEY=
# CINEPLAN_EMAIL_FROM=Cineplan <onboarding@resend.dev>

# ── Data stores — unset uses the bundled mongo/redis containers ───────
# Set to cloud for production:
# CINEPLAN_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cineplan
# CINEPLAN_REDIS_URL=rediss://default:password@host:6379
