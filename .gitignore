# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables — never commit real secrets.
# Only the committed *.env.example templates are tracked.
.env
.env.*
*.env
!.env.example

# Docker bind-mount data (MongoDB / Redis) — keep the folder layout, not the data.
deploy/volumes/*/*
!deploy/volumes/*/.gitkeep

# Frontend Mentor design files — their license forbids redistributing these.
entertainment-web-app-figma/
__MACOSX/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vitest coverage
coverage
