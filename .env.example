# ─────────────────────────────────────────────────────────────────────────────
# Cineplan — ONE env file for the whole project (server, client, Compose).
#   cp .env.example .env   # then fill in the secrets below
#
# Keys are prefixed CINEPLAN_ so this project never clashes with the sibling
# projects on the shared host. The app code reads the plain names (MONGODB_URI,
# SECRET, …):
#   • natively, server/src/config/env.ts aliases CINEPLAN_FOO -> FOO at boot;
#   • in Docker, docker-compose.yml maps CINEPLAN_FOO -> FOO per service.
# Exception: VITE_API_BASE_URL keeps its framework prefix — Vite only exposes
# vars literally starting with VITE_, so it is NOT renamed to CINEPLAN_.
#
# Run Compose from the repo root (reads this .env automatically):
#   docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Required secrets ─────────────────────────────────────────────────────────
CINEPLAN_SECRET=replace-with-a-long-random-string
CINEPLAN_TMDB_API_KEY=your-tmdb-v3-api-key

# ── Runtime mode ─────────────────────────────────────────────────────────────
# Leave blank: native dev resolves to development; the Docker stack resolves to
# production (Compose default), which enables `trust proxy` + Secure cookies
# behind Caddy. Set a value only to force one.
CINEPLAN_NODE_ENV=

# ── Host binding & published ports (Compose only) ────────────────────────────
CINEPLAN_BIND_IP=127.0.0.1
CINEPLAN_CLIENT_HOST_PORT=8081
CINEPLAN_SERVER_HOST_PORT=8091
CINEPLAN_PORT=5000
CINEPLAN_MONGO_HOST_PORT=27017
CINEPLAN_REDIS_HOST_PORT=6379

# ── Public URL — the single knob ─────────────────────────────────────────────
# The app's public origin. In production (behind Caddy) the client + /api are
# same-origin, so this drives the CORS allowlist, the Google OAuth callback, and
# the worker's email deep-links. Leave BLANK for local dev (localhost defaults
# apply). Production: set to your subdomain, e.g. https://cineplan.subashkumar.dev
CINEPLAN_APP_URL=
# Optional explicit override (only if it must differ from CINEPLAN_APP_URL):
# CINEPLAN_CLIENT_ORIGIN=
# Client API base, BAKED INTO THE BUILD (Vite inlines it at build time). Keeps the
# VITE_ prefix (Vite requirement). Leave BLANK:
#   • native dev   → client falls back to http://localhost:5000/api
#   • Docker stack → Compose bakes http://localhost:8091/api (the published server)
# Behind Caddy in prod the client + /api are same-origin, so set this to /api.
VITE_API_BASE_URL=

# ── Data stores (optional) ───────────────────────────────────────────────────
# Leave BLANK to use the bundled mongo/redis containers (Docker) or localhost
# (native dev). Set to managed URLs (Atlas / managed Redis) to override both.
CINEPLAN_MONGODB_URI=
CINEPLAN_REDIS_URL=

# ── Google OAuth (optional — blank disables the Google button) ───────────────
CINEPLAN_GOOGLE_CLIENT_ID=
CINEPLAN_GOOGLE_CLIENT_SECRET=
# Callback derives from CINEPLAN_APP_URL (<app-url>/api/auth/google/callback). Set
# only to override; must EXACTLY match an Authorized redirect URI in Google.
# CINEPLAN_GOOGLE_CALLBACK_URL=

# ── Reminder email via Resend (optional) ─────────────────────────────────────
CINEPLAN_RESEND_API_KEY=
CINEPLAN_EMAIL_FROM=Cineplan <onboarding@resend.dev>
