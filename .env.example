# ── Single source of truth for the whole app ─────────────────────────
# Copy to `.env` (gitignored) and fill in the secrets below. Read by the
# server (npm run dev), the client (Vite), and Docker Compose.

# Required secrets
SECRET=replace-with-a-long-random-string
TMDB_API_KEY=your-tmdb-v3-api-key

# ── Optional overrides (sensible defaults apply if left unset) ────────
# PORT=5000
# CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000
# VITE_API_BASE_URL=http://localhost:5000/api

# ── Google OAuth (optional) ──────────────────────────────────────────
# Set both to enable "Continue with Google". Create an OAuth client at
# https://console.cloud.google.com/apis/credentials and add the callback URL
# below as an Authorized redirect URI. Leave unset to disable the feature.
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Data stores — UNSET means:
#   • host dev (npm run dev): mongodb://localhost:27017, redis://localhost:6379
#   • full Docker stack:      the bundled mongo/redis service containers
# Set these only to point at cloud MongoDB Atlas / managed Redis (production):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/entertainment
# REDIS_URL=rediss://default:password@host:6379

# In deployed environments set NODE_ENV=production — enables Secure +
# SameSite=None auth cookies and makes the secrets mandatory.
# NODE_ENV=production
